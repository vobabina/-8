#include <iostream>
#include "array_utils.h"
#include "matrix_utils.h"

using namespace std;

int main() {
    int arr[5];

    cout << "Enter array elements:\n";
    inputArray(arr, 5);

    cout << "Array: ";
    printArray(arr, 5);

    cout << "Sum = " << sumArray(arr, 5) << endl;

    int matrix[10][10];
    int rows = 2, cols = 2;

    cout << "\nEnter matrix elements:\n";
    inputMatrix(matrix, rows, cols);

    cout << "Matrix:\n";
    printMatrix(matrix, rows, cols);

    return 0;
}